{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/mitchellmos/tribalwars-config/main/schema/worlds.schema.json",
  "title": "Tribal Wars world registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "defaultDurationDays",
    "worlds"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "defaultDurationDays": {
      "type": "integer",
      "minimum": 1,
      "maximum": 365
    },
    "worlds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "url",
          "market",
          "startsAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*[0-9]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "market": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "startsAt": {
            "type": "string",
            "format": "date-time"
          },
          "durationDays": {
            "type": "integer",
            "minimum": 1,
            "maximum": 365
          }
        }
      }
    }
  }
}
